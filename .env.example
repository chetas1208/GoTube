# ============================================
# GoTube Lite — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.

# --- PostgreSQL ---
# Optional: overrides the POSTGRES_* values below when set.
DATABASE_URL=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=gotube
POSTGRES_PASSWORD=gotube_secret
POSTGRES_DB=gotube_lite

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Go API ---
API_PORT=8080
API_ENV=development
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_REFRESH_IDLE_TTL=15m
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# --- S3-Compatible Object Storage (MinIO for local dev) ---
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=gotube_minio
OBJECT_STORAGE_SECRET_KEY=gotube_minio_secret
OBJECT_STORAGE_USE_PATH_STYLE=true
OBJECT_STORAGE_BUCKET_RAW=gotube-raw-videos-dev
OBJECT_STORAGE_BUCKET_PROCESSED=gotube-processed-videos-dev
OBJECT_STORAGE_BUCKET_THUMBNAILS=gotube-thumbnails-dev

# Deprecated Cloudflare R2 fallback variables
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=
# R2_BUCKET_RAW=
# R2_BUCKET_PROCESSED=
# R2_BUCKET_THUMBNAILS=

# --- Worker ---
WORKER_CONCURRENCY=2
WORKER_MAX_RETRIES=3
FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_CRF=23
FFMPEG_PRESET=medium
TEMP_DIR=/tmp/gotube-worker

# --- Next.js Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- Upload Limits ---
MAX_UPLOAD_SIZE_MB=500
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/x-msvideo,video/webm,video/x-matroska

# --- Rate Limiting ---
RATE_LIMIT_AUTH_RPM=20
RATE_LIMIT_UPLOAD_RPM=10
